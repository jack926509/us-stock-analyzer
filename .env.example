# ── Site Protection (optional) ───────────────────────────────
# Set a password to protect the whole site with Basic Auth.
# Leave empty / unset for open access.
SITE_PASSWORD=

# ── Financial Data ───────────────────────────────────────────
# Financial Modeling Prep (https://site.financialmodelingprep.com/)
FMP_API_KEY=your_fmp_api_key_here

# Finnhub (https://finnhub.io/)
FINNHUB_API_KEY=your_finnhub_api_key_here

# ── AI Analysis ──────────────────────────────────────────────
# Anthropic Claude (https://console.anthropic.com/)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Database ─────────────────────────────────────────────────
# Development (local SQLite — no config needed, uses file:./dev.db by default)
# DATABASE_URL=file:./dev.db

# Production (Turso — https://turso.tech/)
# Create a database: turso db create us-stock-analyzer
# Get URL: turso db show us-stock-analyzer --url
# Get token: turso db tokens create us-stock-analyzer
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here
